# Copy to .env and fill in from Firebase Console → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Firebase App Check (reCAPTCHA v3) ---
# 1. Firebase Console → Build → App Check → Register app → reCAPTCHA v3
# 2. Paste the site key below (not the secret key)
# 3. Add your domains (tabakpp.web.app, localhost) in reCAPTCHA admin if prompted
# 4. Local dev: run once with debug enabled, copy the console token, register it under
#    App Check → your web app → Manage debug tokens
# 5. Firestore: App Check → APIs → Cloud Firestore → Enforcement → start with "Monitoring"
#    then switch to "Enforced" after traffic looks good
VITE_FIREBASE_APP_CHECK_KEY=

# Dev: auto-enables debug tokens (default ON in `npm run dev`). Set false to use live attestation locally.
# VITE_FIREBASE_APP_CHECK_DEBUG=true

# Optional: pin a fixed debug token instead of auto-generating one
# VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=
